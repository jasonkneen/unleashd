{
  "name": "unleashd",
  "version": "1.1.0",
  "private": false,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "pnpm --filter @unleashd/server dev",
    "dev:client": "pnpm --filter @unleashd/client dev",
    "build": "pnpm --filter @unleashd/shared build && pnpm --filter @unleashd/server build && node tools/patch-server-dist-shared-imports.cjs && pnpm --filter @unleashd/client build",
    "start": "pnpm --filter @unleashd/server start",
    "test": "node test/api.test.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.2",
    "json-schema-to-typescript": "^15.0.4",
    "ws": "^8.14.2"
  },
  "bin": {
    "unleashd": "./bin/unleashd.js"
  },
  "files": [
    "bin",
    "server/dist",
    "client/dist",
    "shared/dist",
    "server/package.json",
    "client/package.json",
    "shared/package.json"
  ],
  "dependencies": {
    "@nbardy/agent-cli": "workspace:*",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "uuid": "^13.0.0",
    "ws": "^8.14.2",
    "zod": "^3.24.0"
  }
}
